modules = ["nodejs-24", "python-3.11", "postgresql-16", "python3"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/team-all-in-one: ChatGPT 注册面板"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/openai-pool: 账号池编排器"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: FakeMail Bridge"

[[workflows.workflow]]
name = "artifacts/team-all-in-one: ChatGPT 注册面板"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/team-all-in-one && PORT=5000 python3 start.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/openai-pool: 账号池编排器"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/openai-pool && PORT=8000 python3 start.py"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/api-server: FakeMail Bridge"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && FAKEMAIL_PORT=6100 python3 fakemail_bridge.py"
waitForPort = 6100

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5100
externalPort = 4200

[[ports]]
localPort = 6100
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 6000

[[ports]]
localPort = 8084
externalPort = 6800

[[ports]]
localPort = 18421
externalPort = 5173

[[ports]]
localPort = 25594
externalPort = 3000

[[ports]]
localPort = 25595
externalPort = 3003

[nix]
channel = "stable-25_05"
packages = ["ffmpeg-full", "gitFull", "playwright-driver"]
